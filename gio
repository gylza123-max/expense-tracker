<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<style>
@page { size: A4; margin: 0; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, sans-serif; }

.page {
  width: 210mm; height: 297mm;
  page-break-after: always;
  position: relative; overflow: hidden;
  display: flex; flex-direction: column;
}

/* ── DECORATIVE BLOBS ── */
.blob {
  position: absolute; border-radius: 50%;
  opacity: 0.15; pointer-events: none; z-index: 0;
}

/* ── PAGE HEADER ── */
.pg-header {
  padding: 16px 24px 14px;
  text-align: center;
  color: white;
  font-size: 21px; font-weight: 900;
  border-radius: 0 0 30px 30px;
  flex-shrink: 0;
  position: relative; z-index: 1;
}

/* ── PAGE BODY ── */
.pg-body {
  flex: 1;
  padding: 14px 18px 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 10px;
  position: relative; z-index: 1;
}

/* ── CARDS ── */
.card {
  background: white;
  border-radius: 16px;
  padding: 12px 15px;
  border: 2.5px solid;
  box-shadow: 3px 3px 0px;
}

/* ── GRIDS ── */
.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.flex-row { display: flex; gap: 12px; }
.col { flex: 1; }

/* ── STEP ITEMS ── */
.step {
  display: flex; align-items: flex-start; gap: 10px;
  background: white; border-radius: 14px;
  padding: 11px 14px; border: 2.5px solid;
  box-shadow: 3px 3px 0px;
  flex-shrink: 0;
}
.step-num {
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 900; color: white;
  flex-shrink: 0; margin-top: 2px;
}
.step h4 { font-size: 14px; font-weight: 900; margin-bottom: 4px; }
.step ul { font-size: 11.5px; color: #37474F; padding-left: 14px; line-height: 1.8; }

/* ── SCHEDULE ── */
.srow {
  display: flex; align-items: center; gap: 8px;
  padding: 4px 0;
  border-bottom: 1px dashed #E0E0E0;
  font-size: 11.5px;
}
.srow:last-child { border-bottom: none; }
.stime {
  font-size: 11px; font-weight: 900;
  border-radius: 8px; padding: 3px 8px;
  min-width: 62px; text-align: center; flex-shrink: 0;
}

/* ── FOOD ITEMS ── */
.fitem {
  display: flex; align-items: flex-start; gap: 8px;
  background: white; border-radius: 10px;
  padding: 7px 9px; margin-bottom: 6px;
}
.fitem .ico { font-size: 20px; flex-shrink: 0; line-height: 1.2; }
.fitem b { display: block; font-size: 12px; color: #1A1A1A; }
.fitem span { font-size: 11px; color: #546E7A; }

/* ── COMIC ── */
.comic-panel {
  background: white; border-radius: 14px;
  border: 3px solid; padding: 10px 10px 8px;
  box-shadow: 4px 4px 0px;
  position: relative;
  display: flex; flex-direction: column;
}
.panel-badge {
  position: absolute; top: -10px; left: 10px;
  width: 24px; height: 24px; border-radius: 50%;
  background: #FFE066; border: 2px solid #F97316;
  font-size: 12px; font-weight: 900; color: #1A1A1A;
  display: flex; align-items: center; justify-content: center;
}
.speech {
  background: white; border: 2px solid;
  border-radius: 12px; padding: 6px 9px;
  font-size: 10px; line-height: 1.4; color: #1A1A1A;
}
.panel-caption {
  border-radius: 8px; padding: 5px;
  text-align: center; font-size: 11px; font-weight: 900;
  margin-top: 6px; flex-shrink: 0;
}

/* ── INFO BAR ── */
.info-bar {
  background: linear-gradient(135deg, #FFE066, #FFB347);
  border-radius: 14px; padding: 11px 15px;
  text-align: center; font-size: 12.5px; font-weight: bold;
  border: 2px solid #F97316; color: #1A1A1A;
  flex-shrink: 0;
}

/* ── FOOTER ── */
.footer {
  background: #ECEFF1; padding: 9px;
  text-align: center; font-size: 10px; color: #607D8B;
  flex-shrink: 0; z-index: 1; position: relative;
}
</style>
</head>
